      <column caption='caluate f1' datatype='string' name='[Calculation_0670445708775437]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [schools_ai_adoption_pct] &gt;= 50 THEN &quot;High Adoption&quot;&#13;&#10;ELSEIF [schools_ai_adoption_pct] &gt;= 30 THEN &quot;Moderate Adoption&quot;&#13;&#10;ELSE &quot;Low Adoption&quot;&#13;&#10;END' />
